TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# URL мини-приложения (на Render: https://ваш-сервис.onrender.com/webapp)
WEBAPP_URL=https://your-app.onrender.com/webapp
# Базовый URL сервиса (для временных картинок; если не задан — из WEBAPP_URL)
# PUBLIC_APP_URL=https://your-app.onrender.com
# На Render включите webhook, чтобы не было 409 Conflict (один инстанс бота)
# TELEGRAM_USE_WEBHOOK=true

# NanoBanana API — https://docs.nanobananaapi.ai | ключ: https://nanobananaapi.ai/api-key
NANO_BANANA_API_KEY=your_nanobanana_api_key_here
# Базовый URL (по умолчанию уже правильный, менять не нужно)
# NANO_BANANA_BASE_URL=https://api.nanobananaapi.ai
# Опционально: разрешение 1K|2K|4K, соотношение сторон (например 3:4, 16:9)
# NANO_BANANA_RESOLUTION=2K
# NANO_BANANA_ASPECT_RATIO=3:4

# Свой промпт для примерки (кто человек, что одежда). Плейсхолдеры: {personCount}, {productCount}
# NANO_BANANA_PROMPT=Первые {personCount} фото — человек, его лицо и тело. Последние {productCount} — одежда. Надень вещь с последних фото на человека с первых. Один фотореалистичный кадр, нейтральный фон.
